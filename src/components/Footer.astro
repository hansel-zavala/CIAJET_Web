---
import { Image } from 'astro:assets';
import logo from "../assets/image/LogoCIATEJ.png";
---
<!-- ========== FOOTER ========== -->
<footer class="footer-enhanced relative overflow-hidden">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid md:grid-cols-4 gap-8 text-white relative z-10">
            <!-- Logo y descripción -->
            <div class="md:col-span-2">
                <div class="flex items-center space-x-3 mb-4">
                    <a 
                        href="#"
                        class="flex items-center space-x-3 text-2xl font-bold"
                        style="color: #f7f7f7;"
                    >
                        <Image 
                            src={logo}
                            alt="Logo de CIATEJ - Centro Integral de Atención Terapéutico Josué" 
                            class="w-12 h-12 rounded-full shadow-xl"
                            loading="lazy"
                        />
                        <span class="text-2xl font-bold">CIATEJ</span>
                    </a>
                </div>
                <p class="text-gray-300 leading-relaxed mb-6">Transformando vidas a través del apoyo terapéutico y el cuidado profesional. Somos tu aliado en Olanchito para el desarrollo de niños con TEA, TDAH, y retos de lenguaje o aprendizaje.</p>

                <!-- Información de contacto rápida -->
                <div class="space-y-2">
                    <div class="flex items-center">
                        <ion-icon name="call-outline" class="w-4 h-4 mr-3 text-[#0D8F8F]"></ion-icon>
                        <span class="text-sm">9202-2859</span>
                    </div>
                    <div class="flex items-center">
                        <ion-icon name="mail-outline" class="w-4 h-4 mr-3 text-[#0D8F8F]"></ion-icon>
                        <span class="text-sm">info@ciatej.com</span>
                    </div>
                    <div class="flex items-center">
                        <ion-icon name="time-outline" class="w-4 h-4 mr-3 text-[#0D8F8F]"></ion-icon>
                        <span class="text-sm">Lun-Vie: 7:20 AM - 5:00 PM</span>
                    </div>
                </div>
            </div>

            <!-- Navegación -->
            <div>
                <h4 class="font-bold text-lg mb-4 text-[#0D8F8F]">Navegación</h4>
                <ul class="space-y-2 text-sm text-gray-300">
                    <li><a href="#home" class="hover:text-[#0D8F8F] transition-colors duration-300 flex items-center">
                        <ion-icon name="chevron-forward-outline" class="w-3 h-3 mr-2"></ion-icon>
                        Inicio
                    </a></li>
                    <li><a href="#quienes-somos" class="hover:text-[#0D8F8F] transition-colors duration-300 flex items-center">
                        <ion-icon name="chevron-forward-outline" class="w-3 h-3 mr-2"></ion-icon>
                        Quiénes Somos
                    </a></li>
                    <li><a href="#servicios" class="hover:text-[#0D8F8F] transition-colors duration-300 flex items-center">
                        <ion-icon name="chevron-forward-outline" class="w-3 h-3 mr-2"></ion-icon>
                        Servicios
                    </a></li>
                    <li><a href="#equipo" class="hover:text-[#0D8F8F] transition-colors duration-300 flex items-center">
                        <ion-icon name="chevron-forward-outline" class="w-3 h-3 mr-2"></ion-icon>
                        Nuestro Equipo
                    </a></li>
                    <li><a href="#contacto" class="hover:text-[#0D8F8F] transition-colors duration-300 flex items-center">
                        <ion-icon name="chevron-forward-outline" class="w-3 h-3 mr-2"></ion-icon>
                        Contacto
                    </a></li>
                </ul>
            </div>

            <!-- Redes sociales y servicios -->
            <div>
                <h4 class="font-bold text-lg mb-4 text-[#0D8F8F]">Síguenos</h4>
                <div class="flex space-x-4 mb-6">
                    <a href="https://www.facebook.com/share/1Cbv9MRACx/" target="_blank" rel="noopener noreferrer" class="glass-effect w-10 h-10 rounded-full flex items-center justify-center text-gray-300 hover:text-white hover:bg-[#0D8F8F] transition-all duration-300" title="Facebook" aria-label="Visita nuestra página de Facebook">
                        <ion-icon name="logo-facebook" class="w-5 h-5"></ion-icon>
                    </a>
                    <a href="#" target="_blank" rel="noopener noreferrer" class="glass-effect w-10 h-10 rounded-full flex items-center justify-center text-gray-300 hover:text-white hover:bg-[#0D8F8F] transition-all duration-300" title="Instagram" aria-label="Visita nuestra página de Instagram">
                        <ion-icon name="logo-instagram" class="w-5 h-5"></ion-icon>
                    </a>
                    <a href="https://wa.me/50492022859" target="_blank" rel="noopener noreferrer" class="glass-effect w-10 h-10 rounded-full flex items-center justify-center text-gray-300 hover:text-white hover:bg-[#0D8F8F] transition-all duration-300" title="WhatsApp" aria-label="Envíanos un mensaje por WhatsApp">
                        <ion-icon name="logo-whatsapp" class="w-5 h-5"></ion-icon>
                    </a>
                </div>

                <h4 class="font-bold text-lg mb-4 text-[#0D8F8F]">Servicios Destacados</h4>
                <ul class="space-y-2 text-sm text-gray-300">
                    <li class="flex items-center">
                        <ion-icon name="checkmark-circle-outline" class="w-4 h-4 mr-2 text-[#0D8F8F]"></ion-icon>
                        Evaluación TEA/TDAH
                    </li>
                    <li class="flex items-center">
                        <ion-icon name="checkmark-circle-outline" class="w-4 h-4 mr-2 text-[#0D8F8F]"></ion-icon>
                        Terapia del Lenguaje
                    </li>
                    <li class="flex items-center">
                        <ion-icon name="checkmark-circle-outline" class="w-4 h-4 mr-2 text-[#0D8F8F]"></ion-icon>
                        Apoyo Psicoeducativo
                    </li>
                </ul>
            </div>
        </div>

        <!-- Línea divisoria con gradiente -->
        <div class="mt-12 pt-8 border-t border-gray-600">
            <div class="flex flex-col md:flex-row justify-between items-center">
                <p class="text-gray-400 text-sm">&copy; 2026 CIATEJ. Todos los derechos reservados.</p>
                <p class="text-gray-400 text-sm mt-2 md:mt-0">Hecho con ❤️ para familias especiales</p>
            </div>
        </div>
    </div>

    <!-- Elementos decorativos -->
    <div class="floating-shape shape-1 hidden lg:block opacity-30"></div>
    <div class="floating-shape shape-3 hidden lg:block opacity-20"></div>
</footer>
