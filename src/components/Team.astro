---
---
<!-- ========== SECCIÓN NUESTRO EQUIPO ========== -->
<section id="equipo" class="py-16 lg:py-24 bg-pattern relative">
    <div class="floating-shape shape-3 hidden lg:block"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center fade-in">
            <h2 class="text-4xl font-bold tracking-tight title-shadow mb-4">
                <span class="text-gradient">Nuestro</span> Equipo
            </h2>
            <p class="mt-4 max-w-3xl mx-auto text-xl text-gray-600 leading-relaxed">
                <strong class="text-[#0A2A4E]">Profesionales especializados</strong> comprometidos con brindar la mejor atención a cada persona y familia
            </p>
        </div>

        <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Psicólogo 1 -->
            <div class="team-card p-6 rounded-2xl hover-lift text-center scroll-animate">
                <div class="team-avatar w-28 h-28 rounded-full mx-auto mb-6 overflow-hidden ring-4 ring-[#0D8F8F]/20">
                    <img src="/assets/image/team/Jefa.jpg" alt="Terapeuta, Jefa del Equipo" class="w-full h-full object-cover">
                </div>
                <h3 class="text-xl font-bold mb-2 text-gradient">Olga Bidilia Zavala Diaz</h3>
                <p class="text-[#005960] font-semibold mb-2">Terapeuta, Jefa del Equipo</p>
                <p class="text-sm text-gray-600 leading-relaxed">Especialista en TEA y TDAH</p>
                <div class="mt-4 flex justify-center space-x-3">
                    <div class="w-2 h-2 bg-[#0D8F8F] rounded-full"></div>
                    <div class="w-2 h-2 bg-[#005960] rounded-full"></div>
                    <div class="w-2 h-2 bg-[#0A2A4E] rounded-full"></div>
                </div>
            </div>

            <!-- Psicólogo 2 -->
            <div class="team-card p-6 rounded-2xl hover-lift text-center scroll-animate">
                <div class="team-avatar w-28 h-28 rounded-full mx-auto mb-6 overflow-hidden ring-4 ring-[#0D8F8F]/20">
                    <img src="/assets/image/team/Mateo.jpg" alt="Psicólogo Infantil" class="w-full h-full object-cover">
                </div>
                <h3 class="text-xl font-bold mb-2 text-gradient">Robert Mateo Martinez Zavala</h3>
                <p class="text-[#005960] font-semibold mb-2">Psicólogo Infantil</p>
                <p class="text-sm text-gray-600 leading-relaxed">Especialista en intervención conductual</p>
                <div class="mt-4 flex justify-center space-x-3">
                    <div class="w-2 h-2 bg-[#0D8F8F] rounded-full"></div>
                    <div class="w-2 h-2 bg-[#005960] rounded-full"></div>
                    <div class="w-2 h-2 bg-[#0A2A4E] rounded-full"></div>
                </div>
            </div>

            <!-- Terapeuta 1 -->
            <div class="team-card p-6 rounded-2xl hover-lift text-center scroll-animate">
                <div class="team-avatar w-28 h-28 rounded-full mx-auto mb-6 overflow-hidden ring-4 ring-[#0D8F8F]/20">
                    <img src="/assets/image/team/GustavoRodriguez.jpeg" alt="Psicólogo General" class="w-full h-full object-cover">
                </div>
                <h3 class="text-xl font-bold mb-2 text-gradient">Gustavo Adolfo Rodriguez Aleman</h3>
                <p class="text-[#005960] font-semibold mb-2">Lic. Psicólogia</p>
                <p class="text-sm text-gray-600 leading-relaxed">Especialista en comunicación</p>
                <div class="mt-4 flex justify-center space-x-3">
                    <div class="w-2 h-2 bg-[#0D8F8F] rounded-full"></div>
                    <div class="w-2 h-2 bg-[#005960] rounded-full"></div>
                    <div class="w-2 h-2 bg-[#0A2A4E] rounded-full"></div>
                </div>
            </div>

            <!-- Terapeuta 2 -->
            <div class="team-card p-6 rounded-2xl hover-lift text-center scroll-animate">
                <div class="team-avatar w-28 h-28 rounded-full mx-auto mb-6 overflow-hidden ring-4 ring-[#0D8F8F]/20">
                    <img src="/assets/image/team/Hansel.jpg" alt="Soporte Tecnico" class="w-full h-full object-cover">
                </div>
                <h3 class="text-xl font-bold mb-2 text-gradient">Hansel Samir Martinez Zavala</h3>
                <p class="text-[#005960] font-semibold mb-2">Soporte Tecnico</p>
                <p class="text-sm text-gray-600 leading-relaxed">Especialista en tecnologia</p>
                <div class="mt-4 flex justify-center space-x-3">
                    <div class="w-2 h-2 bg-[#0D8F8F] rounded-full"></div>
                    <div class="w-2 h-2 bg-[#005960] rounded-full"></div>
                    <div class="w-2 h-2 bg-[#0A2A4E] rounded-full"></div>
                </div>
            </div>
        </div>
    </div>
</section>
