---
import { Image } from 'astro:assets';
import olgaImg from '../assets/image/team/OlgaCIATEJ.jpeg';
import deysiImg from '../assets/image/team/DeysiCIATEJ.jpeg';
import gustavoImg from '../assets/image/team/GustavoCIATEJ.jpeg';
import hanselImg from '../assets/image/team/HanselCIATEJ.jpeg';

const team = [
  [olgaImg, "Olga Bidilia Zavala Diaz", "Licenciada en Educación Especial", "Especialista en Terapia de lenguaje"],
  [deysiImg, "Deysi Almendares", "Licenciada en Educación Especial", "Especialista en Terapia de lenguaje"],
  [gustavoImg, "Gustavo Adolfo Rodriguez Aleman", "Licenciado en Psicología", "Especialista en Terapia psicológica"],
  [hanselImg, "Hansel Samir Martinez Zavala", "Ingeniero en Informática", "Administrador"],
];
---

<section id="equipo" class="section-shell bg-[#f3fbf8] bg-pattern">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <span class="section-kicker">Nuestro equipo</span>
      <h2 class="section-title mt-5">Profesionales que escuchan antes de intervenir.</h2>
      <p class="section-lead mt-6">Un equipo comprometido con brindar atención clara, humana y especializada a cada familia.</p>
    </div>

    <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {team.map(([image, name, role, detail]) => (
        <article class="team-card p-5 hover-lift text-center scroll-animate">
          <div class="team-avatar w-32 h-32 rounded-[2rem] mx-auto mb-6 overflow-hidden ring-1 ring-[#0b8f88]/15">
            <Image src={image} alt={`${name}, ${role} en CIATEJ`} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <h3 class="text-lg font-extrabold text-[#063b45] mb-2">{name}</h3>
          <p class="text-[#0b8f88] font-bold text-sm mb-2">{role}</p>
          <p class="text-sm text-slate-600 leading-relaxed">{detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>
