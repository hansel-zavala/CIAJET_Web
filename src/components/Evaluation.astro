---
const processes = [
  {
    icon: "clipboard-outline",
    label: "Quiero una valoración",
    title: "Proceso de evaluación",
    description: "Conocemos las necesidades del niño o niña y orientamos a la familia con claridad.",
    steps: [
      ["01", "Solicitud inicial", "Completa el formulario y cuéntanos brevemente el motivo de consulta."],
      ["02", "Entrevista y documentos", "Conocemos la historia de desarrollo y recibimos los documentos disponibles."],
      ["03", "Evaluación y análisis", "Aplicamos las pruebas necesarias y nuestro equipo integra los resultados."],
      ["04", "Entrega de resultados", "Explicamos los hallazgos y entregamos recomendaciones para continuar."],
    ],
  },
  {
    icon: "school-outline",
    label: "Quiero iniciar terapias",
    title: "Proceso de matrícula",
    description: "Organizamos el ingreso al servicio recomendado y preparamos el inicio del acompañamiento.",
    steps: [
      ["01", "Solicitud de ingreso", "Presenta una evaluación de CIATEJ o una evaluación externa reciente."],
      ["02", "Revisión del expediente", "Verificamos los documentos y las recomendaciones terapéuticas."],
      ["03", "Pago de matrícula", "Se realiza el pago único correspondiente al inicio del proceso."],
      ["04", "Horario e inicio", "Confirmamos el servicio, la frecuencia, el profesional y el horario."],
    ],
  },
];

const sharedDocuments = [
  {
    icon: "id-card-outline",
    title: "Identificación de los responsables",
    text: "Copia legible del DNI de los padres, madres o encargados legales disponibles.",
  },
  {
    icon: "document-text-outline",
    title: "Partida de nacimiento",
    text: "Copia legible de la partida de nacimiento del niño o niña.",
  },
  {
    icon: "medkit-outline",
    title: "Referencia médica, si dispone de ella",
    text: "Puede presentar una referencia médica actualizada. No es obligatoria para solicitar una primera evaluación.",
  },
];

const enrollmentDocuments = [
  {
    title: "Evaluación externa reciente, si aplica",
    text: "Si el niño o niña fue evaluado en otro centro, presenta el informe más reciente disponible.",
  },
  {
    title: "Comprobante de pago, si ya fue realizado",
    text: "Presenta el comprobante correspondiente al pago de matrícula.",
  },
];

const importantInformation = [
  "La matrícula se realiza una sola vez al iniciar el proceso.",
  "Los documentos permiten completar el expediente del niño o niña.",
  "Toda la información es confidencial y de uso exclusivo de CIATEJ.",
];
---

<section id="evaluacion" class="section-shell bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <span class="section-kicker">Matrícula y evaluación</span>
      <h2 class="section-title mt-5">Elige el proceso que tu familia necesita.</h2>
      <p class="section-lead mt-6 max-w-3xl mx-auto">
        Puedes solicitar una primera evaluación o iniciar la matrícula con una evaluación reciente. En ambos casos, nuestro equipo te orientará paso a paso.
      </p>
    </div>

    <div class="mt-14 grid lg:grid-cols-2 gap-6">
      {processes.map(({ icon, label, title, description, steps }) => (
        <article class="relative overflow-hidden rounded-[1.75rem] border border-[#d8ebe7] bg-[#f8fcfb] p-7 sm:p-9 shadow-[0_16px_45px_rgba(8,64,73,.08)]">
          <div class="absolute top-0 right-0 w-36 h-36 rounded-full bg-[#dff8f1]/80 blur-3xl translate-x-12 -translate-y-12 pointer-events-none"></div>
          <header class="relative flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 rounded-2xl bg-[#0b8f88] text-white flex items-center justify-center">
              <ion-icon name={icon} class="text-2xl" aria-hidden="true"></ion-icon>
            </div>
            <div>
              <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-[#0b8f88] mb-2">{label}</p>
              <h3 class="text-2xl sm:text-[1.7rem] font-extrabold leading-tight text-[#063b45]">{title}</h3>
            </div>
          </header>

          <p class="relative mt-5 text-slate-600 leading-relaxed">{description}</p>

          <ol class="relative mt-8 space-y-0">
            {steps.map(([number, stepTitle, text], index) => (
              <li class="grid grid-cols-[2.5rem_1fr] gap-4">
                <div class="flex flex-col items-center" aria-hidden="true">
                  <span class="w-10 h-10 rounded-full border border-[#b9ddd7] bg-white text-xs font-extrabold text-[#0b8f88] flex items-center justify-center">{number}</span>
                  {index < steps.length - 1 && <span class="w-px flex-1 min-h-7 bg-[#cce4df]"></span>}
                </div>
                <div class:list={["pb-7", index === steps.length - 1 && "pb-0"]}>
                  <h4 class="font-extrabold text-[#063b45]">{stepTitle}</h4>
                  <p class="mt-2 text-sm text-slate-600 leading-relaxed">{text}</p>
                </div>
              </li>
            ))}
          </ol>
        </article>
      ))}
    </div>

    <div class="mt-16 max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <span class="section-kicker">Prepara tu expediente</span>
        <h3 class="mt-5 text-3xl sm:text-4xl font-extrabold tracking-tight text-[#063b45]">Documentos requeridos</h3>
        <p class="mt-4 text-slate-600 leading-relaxed">Estos documentos base se utilizan tanto para evaluación como para matrícula.</p>
      </div>

      <div class="mt-9 grid lg:grid-cols-[1.35fr_.85fr] gap-6 items-start">
        <div class="rounded-[1.75rem] border border-[#d8ebe7] bg-white p-6 sm:p-8 shadow-[0_14px_40px_rgba(8,64,73,.07)]">
          <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-[#0b8f88] mb-3">Para ambos procesos</p>
          <div class="divide-y divide-[#d8ebe7]">
            {sharedDocuments.map(({ icon, title, text }) => (
              <div class="flex items-start gap-4 py-5 first:pt-2 last:pb-2">
                <div class="shrink-0 w-10 h-10 rounded-xl bg-[#e9f7f4] text-[#0b8f88] flex items-center justify-center">
                  <ion-icon name={icon} class="text-xl" aria-hidden="true"></ion-icon>
                </div>
                <div>
                  <h4 class="font-extrabold text-[#063b45]">{title}</h4>
                  <p class="mt-2 text-sm text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <aside class="rounded-[1.75rem] bg-[#063b45] text-white p-6 sm:p-8 shadow-[0_18px_45px_rgba(6,59,69,.18)]">
          <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-[#9ee0d8]">Solo para matrícula</p>
          <h4 class="mt-3 text-2xl font-extrabold">Documentos adicionales</h4>
          <div class="mt-5 divide-y divide-white/15">
            {enrollmentDocuments.map(({ title, text }) => (
              <div class="py-5 first:pt-2 last:pb-1">
                <div class="flex items-start gap-3">
                  <ion-icon name="checkmark-circle" class="shrink-0 mt-0.5 text-xl text-[#9ee0d8]" aria-hidden="true"></ion-icon>
                  <div>
                    <h5 class="font-bold">{title}</h5>
                    <p class="mt-2 text-sm text-white/70 leading-relaxed">{text}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </aside>
      </div>

      <div class="mt-6 rounded-[1.5rem] border border-[#cce4df] bg-[#eff9f6] p-6 sm:p-8">
        <div class="grid md:grid-cols-[auto_1fr] gap-5 items-start">
          <div class="w-11 h-11 rounded-xl bg-white text-[#0b8f88] flex items-center justify-center shadow-sm">
            <ion-icon name="shield-checkmark-outline" class="text-2xl" aria-hidden="true"></ion-icon>
          </div>
          <div>
            <h4 class="text-xl font-extrabold text-[#063b45]">Información importante</h4>
            <ul class="mt-4 grid md:grid-cols-3 gap-3" role="list">
              {importantInformation.map((information) => (
                <li class="flex items-start gap-2 text-sm text-slate-600 leading-relaxed">
                  <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#0b8f88] shrink-0" aria-hidden="true"></span>
                  <span>{information}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <h3 class="text-3xl font-extrabold tracking-tight text-[#063b45]">Inicia tu proceso con nosotros</h3>
        <p class="mt-4 section-lead max-w-2xl mx-auto">Completa el formulario e indica si deseas solicitar una evaluación o iniciar una matrícula. Nuestro equipo se pondrá en contacto contigo.</p>
      </div>

      <div class="liquid-card p-3 sm:p-5">
        <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSdtCZbR2kZZBdL7HkIZVt8IMMf6O55QWA6AUBaXQ9NkYtxZWw/viewform?embedded=true" title="Formulario de solicitud de evaluación o matrícula en CIATEJ" width="100%" height="800" class="form-iframe bg-white border-0" style="max-width: 720px; margin: 0 auto; display: block;" allowfullscreen>Loading...</iframe>
      </div>
      <p class="mt-4 text-xs text-center text-slate-500">Tu información es confidencial y será tratada con el máximo respeto y profesionalismo.</p>
    </div>
  </div>
</section>
