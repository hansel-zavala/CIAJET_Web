---

---

<header
  class="bg-white/80 backdrop-blur-md fixed top-0 left-0 right-0 z-50 shadow-sm translate-y-0 transition-transform duration-300"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="#home"
        class="flex items-center space-x-3 text-2xl font-bold"
        style="color: #0A2A4E;"
      >
        <img
          src="/assets/image/Logo_CIATEJ.PNG"
          alt="Logo del Centro Integral de Atención Terapéutico Josué (CIATEJ)"
          class="w-12 h-12 rounded-lg shadow-xl"
        />
        <span>CIATEJ</span>
      </a>

      <!-- Navegación para escritorio -->
      <nav class="hidden lg:flex items-center space-x-4 xl:space-x-8">
        <a
          href="#home"
          class="text-gray-600 hover:text-[#0D8F8F] transition-colors duration-300 nav-link"
          >Inicio</a
        >
        <a
          href="#quienes-somos"
          class="text-gray-600 hover:text-[#0D8F8F] transition-colors duration-300 nav-link"
          >Quiénes Somos</a
        >
        <a
          href="#servicios"
          class="text-gray-600 hover:text-[#0D8F8F] transition-colors duration-300 nav-link"
          >Servicios</a
        >
        <a
          href="#equipo"
          class="text-gray-600 hover:text-[#0D8F8F] transition-colors duration-300 nav-link"
          >Nuestro Equipo</a
        >
        <a
          href="#evaluacion"
          class="text-gray-600 hover:text-[#0D8F8F] transition-colors duration-300 nav-link"
          >Solicitud de Evaluación</a
        >
        <a
          href="#contacto"
          class="text-gray-600 hover:text-[#0D8F8F] transition-colors duration-300 nav-link"
          >Contacto</a
        >
      </nav>

      <!-- Botón de Menú para móvil -->
      <div class="lg:hidden relative z-50">
        <button
          id="mobile-menu-button"
          class="text-gray-600 hover:text-[#0D8F8F] focus:outline-none"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <ion-icon name="menu-outline" class="w-7 h-7" aria-hidden="true"></ion-icon>
        </button>
      </div>
    </div>
  </div>

  <!-- Fondo oscuro detrás del menú -->
  <div
    id="mobile-menu-backdrop"
    class="hidden lg:hidden fixed top-16 left-0 bottom-0 w-[40vw] h-screen z-30 bg-black/50 backdrop-blur-sm transition-opacity duration-300"
  >
  </div>

  <!-- Menú desplegable para móvil -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden fixed top-16 right-0 bottom-0 h-screen w-[60vw] z-40 bg-gradient-to-br from-[#0A2A4E] via-[#005960] to-[#0D8F8F] shadow-2xl"
  >
    <div class="flex flex-col h-full overflow-y-auto">
      <!-- Header del menú con logo -->
      <div
        class="flex items-center justify-center py-6 px-6 border-b border-white/20"
      >
        <img
          src="/assets/image/Logo_CIATEJ.PNG"
          alt="Logo de CIATEJ en menú móvil"
          class="w-16 h-16 rounded-full bg-white p-2 shadow-lg"
        />
        <div class="ml-4 text-white">
          <h2 class="text-xl font-bold">CIATEJ</h2>
          <p class="text-sm opacity-80">
            Centro Integral de Atención Terapéutico Josué
          </p>
        </div>
      </div>

      <!-- Opciones del menú -->
      <div class=" px-6 py-5 space-y-2">
        <a
          href="#home"
          class="flex items-center px-4 py-3 rounded-xl bg-white/10 backdrop-blur-sm text-white hover:bg-white/20 transition-all duration-300 nav-link"
        >
          <ion-icon name="home-outline" class="w-6 h-6 mr-4"></ion-icon>
          <span class="font-medium">Inicio</span>
        </a>
        <a
          href="#quienes-somos"
          class="flex items-center px-4 py-3 rounded-xl bg-white/10 backdrop-blur-sm text-white hover:bg-white/20 transition-all duration-300 nav-link"
        >
          <ion-icon name="information-circle-outline" class="w-6 h-6 mr-4"
          ></ion-icon>
          <span class="font-medium">Quiénes Somos</span>
        </a>
        <a
          href="#servicios"
          class="flex items-center px-4 py-3 rounded-xl bg-white/10 backdrop-blur-sm text-white hover:bg-white/20 transition-all duration-300 nav-link"
        >
          <ion-icon name="medical-outline" class="w-6 h-6 mr-4"></ion-icon>
          <span class="font-medium">Servicios</span>
        </a>
        <a
          href="#equipo"
          class="flex items-center px-4 py-3 rounded-xl bg-white/10 backdrop-blur-sm text-white hover:bg-white/20 transition-all duration-300 nav-link"
        >
          <ion-icon name="people-outline" class="w-6 h-6 mr-4"></ion-icon>
          <span class="font-medium">Nuestro Equipo</span>
        </a>
        <a
          href="#evaluacion"
          class="flex items-center px-4 py-3 rounded-xl bg-white/10 backdrop-blur-sm text-white hover:bg-white/20 transition-all duration-300 nav-link"
        >
          <ion-icon name="clipboard-outline" class="w-6 h-6 mr-4"></ion-icon>
          <span class="font-medium">Solicitud de Evaluación</span>
        </a>
        <a
          href="#contacto"
          class="flex items-center px-4 py-3 rounded-xl bg-white/10 backdrop-blur-sm text-white hover:bg-white/20 transition-all duration-300 nav-link"
        >
          <ion-icon name="call-outline" class="w-6 h-6 mr-4"></ion-icon>
          <span class="font-medium">Contacto</span>
        </a>
      </div>

      <!-- Información de contacto -->
      <div class="px-5 pb-6 py-55">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
          <h3 class="text-white font-semibold mb-3 text-center">
            Contacto Rápido
          </h3>
          <div class="space-y-2 text-sm text-white/80">
            <div class="flex items-center">
              <ion-icon name="call-outline" class="w-4 h-4 mr-3"></ion-icon>
              <span>9202-2859</span>
            </div>
            <div class="flex items-center">
              <ion-icon name="mail-outline" class="w-4 h-4 mr-3"></ion-icon>
              <span>info@ciatej.com</span>
            </div>
            <div class="flex items-center">
              <ion-icon name="time-outline" class="w-4 h-4 mr-3"></ion-icon>
              <span>Lun-Vie: 7:20 AM - 5:00 PM</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Logic for Header and Mobile Menu
  document.addEventListener("DOMContentLoaded", () => {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileMenuBackdrop = document.getElementById("mobile-menu-backdrop");
    const header = document.querySelector("header");
    const navLinks = document.querySelectorAll(".nav-link");

    if (!mobileMenuButton || !mobileMenu || !mobileMenuBackdrop || !header)
      return;

    let lastScrollTop = 0;
    let scrollThrottle: ReturnType<typeof setTimeout>;
    let isHeaderVisible = true;

    // Initialize header
    header.classList.add("translate-y-0");

    // Toggle Mobile Menu
    mobileMenuButton.addEventListener("click", () => {
      const isHidden = mobileMenu.classList.contains("hidden");
      if (isHidden) {
        mobileMenu.classList.remove("hidden");
        mobileMenuBackdrop.classList.remove("hidden");
        mobileMenu.classList.add("show");
        header.classList.remove("-translate-y-full");
        header.classList.add("translate-y-0");
        isHeaderVisible = true;
        document.body.style.overflow = "hidden";
        mobileMenuButton.setAttribute("aria-expanded", "true");
      } else {
        closeMenu();
      }
    });

    // Close on backdrop click
    mobileMenuBackdrop.addEventListener("click", closeMenu);

    // Close on menu click outside
    mobileMenu.addEventListener("click", (e) => {
      if (e.target === mobileMenu) closeMenu();
    });

    // Close on link click
    navLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        closeMenu();
        // Smooth scroll is handled by CSS scroll-behavior: smooth, but we can enforce it if needed
        // The default anchor behavior works fine with scroll-smooth class on html
      });
    });

    function closeMenu() {
      mobileMenu?.classList.add("hidden");
      mobileMenuBackdrop?.classList.add("hidden");
      mobileMenu?.classList.remove("show");
      document.body.style.overflow = "";
      mobileMenuButton?.setAttribute("aria-expanded", "false");
    }

    // Header Scroll Behavior - REMOVED to keep header fixed
    // function handleHeaderScroll() { ... }
    // window.addEventListener('scroll', ...);

    // Active Link Highlighting (Scroll Spy)
    const observerOptions = {
      root: null,
      rootMargin: "0px",
      threshold: 0.4,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute("id");
          document.querySelectorAll(".nav-link").forEach((link) => {
            link.classList.remove("nav-link-active");
          });
          const activeLinks = document.querySelectorAll(
            `.nav-link[href="#${id}"]`,
          );
          activeLinks.forEach((activeLink) => {
            activeLink.classList.add("nav-link-active");
          });
        }
      });
    }, observerOptions);

    document.querySelectorAll("section").forEach((section) => {
      observer.observe(section);
    });
  });
</script>
