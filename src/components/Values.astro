---
const values = [
  ["hand-left-outline", "Respeto", "Reconocemos la dignidad y singularidad de cada niño, joven y familia."],
  ["star-outline", "Compromiso", "Sostenemos cada intervención con responsabilidad, seguimiento y excelencia."],
  ["heart-circle-outline", "Inclusión", "Promovemos participación real, accesible y con igualdad de oportunidades."],
  ["diamond-outline", "Calidad", "Trabajamos con criterios profesionales, actualizados y centrados en la persona."],
  ["people-outline", "Trabajo en equipo", "Coordinamos miradas clínicas, educativas y familiares para avanzar juntos."],
  ["heart-outline", "Amor y vocación", "Cuidamos cada interacción con calidez, paciencia y dedicación genuina."],
];
---

<section class="section-shell bg-[#f3fbf8]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <span class="section-kicker">Nuestros valores</span>
      <h2 class="section-title mt-5">Principios que se sienten en cada sesión.</h2>
      <p class="section-lead mt-6">Una forma de trabajar tranquila, ética y cercana para que cada familia sepa qué esperar y cómo avanzar.</p>
    </div>

    <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {values.map(([icon, title, text]) => (
        <article class="soft-card p-7 hover-lift scroll-animate">
          <div class="value-circle mb-6 mx-0">
            <ion-icon name={icon} class="text-2xl" aria-hidden="true"></ion-icon>
          </div>
          <h3 class="text-xl font-extrabold text-[#063b45] mb-3">{title}</h3>
          <p class="text-slate-600 leading-relaxed">{text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
