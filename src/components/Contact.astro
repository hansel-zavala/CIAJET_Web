---
import { Image } from 'astro:assets';
import portada from "../assets/image/portadaCIATEJ.webp";

const contacts = [
  ["location-outline", "Ubicación", "Preguntar por WhatsApp o por llamada"],
  ["call-outline", "Teléfonos", "+504 9202-2859"],
  ["mail-outline", "Correo Electrónico", "info@ciatej.com"],
  ["time-outline", "Horario", "Lunes a Viernes · 7:20 AM - 5:00 PM"],
];
---

<section id="contacto" class="section-shell bg-[#f3fbf8]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-[.95fr_1.05fr] gap-12 lg:gap-16 items-center">
      <div class="relative group liquid-card p-3 overflow-hidden">
        <Image
          src={portada}
          alt="Instalaciones del Centro Integral de Atención Terapéutico Josué (CIATEJ) en Olanchito"
          class="w-full aspect-[16/11] object-cover rounded-[1.5rem] transform group-hover:scale-[1.03] transition-transform duration-700 ease-in-out"
          loading="lazy"
        />
      </div>

      <div>
        <span class="section-kicker">Contacto</span>
        <h2 class="section-title mt-5">Estamos cerca para resolver tus preguntas.</h2>
        <p class="section-lead mt-6">Si tienes alguna consulta sobre servicios, terapias o deseas programar una cita, contáctanos. Nuestro equipo te atenderá con calidez.</p>

        <div class="mt-9 grid sm:grid-cols-2 gap-5">
          {contacts.map(([icon, title, text]) => (
            <article class="soft-card p-6 hover-lift">
              <div class="w-11 h-11 rounded-2xl bg-[#dff8f1] text-[#0b8f88] flex items-center justify-center mb-4">
                <ion-icon name={icon} class="w-6 h-6" aria-hidden="true"></ion-icon>
              </div>
              <h3 class="font-extrabold text-[#063b45] mb-2">{title}</h3>
              <p class="text-slate-600 text-sm leading-relaxed break-words">{text}</p>
            </article>
          ))}
        </div>

        <a href="https://wa.me/50492022859" target="_blank" rel="noopener noreferrer" class="btn-modern btn-filled mt-8">Escribir por WhatsApp</a>
      </div>
    </div>
  </div>
</section>
