---
---
<!-- ========== SECCIÓN CONTACTO ========== -->
<section id="contacto" class="py-16 lg:py-24 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
            <h2 class="text-3xl font-bold tracking-tight" style="color: #0A2A4E;">¿Tienes Preguntas? Contáctanos</h2>
            <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-600">
                Estamos aquí para ayudarte. Escríbenos o visítanos.
            </p>
        </div>
        <div class="mt-12 grid lg:grid-cols-2 gap-12">
            <!-- Formulario de Contacto -->
            <div class="bg-white p-8 rounded-lg shadow-md">
                <form action="#" method="POST">
                    <div class="space-y-6">
                        <div>
                            <label for="name" class="block text-sm font-medium text-gray-700">Nombre Completo</label>
                            <input type="text" name="name" id="name" autocomplete="name" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-[#0D8F8F] focus:border-[#0D8F8F]">
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-700">Correo Electrónico</label>
                            <input type="email" name="email" id="email" autocomplete="email" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-[#0D8F8F] focus:border-[#0D8F8F]">
                        </div>
                        <div>
                            <label for="message" class="block text-sm font-medium text-gray-700">Mensaje</label>
                            <textarea id="message" name="message" rows="4" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-[#0D8F8F] focus:border-[#0D8F8F]"></textarea>
                        </div>
                        <div>
                            <button type="submit" class="w-full text-center px-6 py-3 text-white font-semibold rounded-lg shadow-md transition-colors duration-300" style="background-color: #0A2A4E;">
                                Enviar Mensaje
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <!-- Información y Mapa -->
            <div class="space-y-8">
                <div class="space-y-4">
                    <h3 class="text-xl font-semibold" style="color:#005960">Información de Contacto</h3>
                        <p class="flex items-center"><ion-icon name="location-outline" class="w-5 h-5 mr-3" style="color:#0D8F8F"></ion-icon> Colonia la Conquista 8 cuadras al norte de la calle que conduce al Hospital Aníbal Murillo Escobar</p>
                        <p class="flex items-center"><ion-icon name="call-outline" class="w-5 h-5 mr-3" style="color:#0D8F8F"></ion-icon> 9202-2859</p>
                        <p class="flex items-center"><ion-icon name="mail-outline" class="w-5 h-5 mr-3" style="color:#0D8F8F"></ion-icon> contacto@centrojosue.org</p>
                        <p class="flex items-center"><ion-icon name="time-outline" class="w-5 h-5 mr-3" style="color:#0D8F8F"></ion-icon> Lunes a Viernes: 9:00 AM - 6:00 PM</p>
                </div>
                <div class="h-64 bg-gray-200 rounded-lg shadow-inner flex items-center justify-center">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m13!1m8!1m3!1d497.27961240788085!2d-86.57651763451744!3d15.493378813370235!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMTXCsDI5JzM2LjYiTiA4NsKwMzQnMzUuMCJX!5e1!3m2!1ses!2shn!4v1760077776242!5m2!1ses!2shn" width="100%" height="100%" style="border:0; border-radius: 0.5rem;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
        </div>
    </div>
</section>
