---

---

<!-- ========== SECCIÓN CONTACTO ========== -->
<section id="contacto" class="py-16 lg:py-24 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
            <h2
                class="text-3xl font-bold tracking-tight"
                style="color: #0A2A4E;"
            >
                ¿Tienes Preguntas? Contáctanos
            </h2>
            <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-600">
                Estamos aquí para ayudarte. Escríbenos o visítanos.
            </p>
        </div>
        <div class="mt-16 grid lg:grid-cols-2 gap-12 lg:items-center">
            <!-- Imagen del Centro -->
            <div class="relative group rounded-2xl overflow-hidden shadow-2xl">
                <div
                    class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none"
                >
                </div>
                <img
                    src="/assets/image/Portada_CIATEJ.png"
                    alt="Instalaciones del Centro Integral de Atención Terapéutico Josué (CIATEJ) en Olanchito"
                    class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-in-out"
                    loading="lazy"
                />
            </div>

            <!-- Información -->
            <div class="space-y-8">
                <div class="space-y-4">
                    <h3
                        class="text-2xl lg:text-3xl font-bold tracking-tight"
                        style="color:#005960"
                    >
                        Estamos más cerca de ti
                    </h3>
                    <p class="text-gray-600 text-lg leading-relaxed text-justify">
                        Si tienes alguna consulta sobre nuestros servicios,
                        terapias o deseas programar una cita, no dudes en
                        contactarnos a través de los siguientes medios. Nuestro
                        equipo estará encantado de atenderte.
                    </p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <!-- Ubicacion -->
                    <div
                        class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
                    >
                        <div
                            class="w-12 h-12 rounded-full flex items-center justify-center mb-4"
                            style="background-color: rgba(13, 143, 143, 0.1);"
                        >
                            <ion-icon
                                name="location-outline"
                                class="w-6 h-6"
                                style="color:#0D8F8F"></ion-icon>
                        </div>
                        <h4 class="font-bold text-gray-900 mb-1 text-lg">
                            Ubicación
                        </h4>
                        <p class="text-gray-600 text-sm">
                            Preguntar por WhatsApp o por llamada
                        </p>
                    </div>

                    <!-- Telefono -->
                    <div
                        class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
                    >
                        <div
                            class="w-12 h-12 rounded-full flex items-center justify-center mb-4"
                            style="background-color: rgba(13, 143, 143, 0.1);"
                        >
                            <ion-icon
                                name="call-outline"
                                class="w-6 h-6"
                                style="color:#0D8F8F"></ion-icon>
                        </div>
                        <h4 class="font-bold text-gray-900 mb-1 text-lg">
                            Teléfonos
                        </h4>
                        <p class="text-gray-600 text-sm">+504 9202-2859</p>
                    </div>

                    <!-- Correo -->
                    <div
                        class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
                    >
                        <div
                            class="w-12 h-12 rounded-full flex items-center justify-center mb-4"
                            style="background-color: rgba(13, 143, 143, 0.1);"
                        >
                            <ion-icon
                                name="mail-outline"
                                class="w-6 h-6"
                                style="color:#0D8F8F"></ion-icon>
                        </div>
                        <h4 class="font-bold text-gray-900 mb-1 text-lg">
                            Correo Electrónico
                        </h4>
                        <p class="text-gray-600 text-sm break-all">
                            info@ciatej.com
                        </p>
                    </div>

                    <!-- Horario -->
                    <div
                        class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
                    >
                        <div
                            class="w-12 h-12 rounded-full flex items-center justify-center mb-4"
                            style="background-color: rgba(13, 143, 143, 0.1);"
                        >
                            <ion-icon
                                name="time-outline"
                                class="w-6 h-6"
                                style="color:#0D8F8F"></ion-icon>
                        </div>
                        <h4 class="font-bold text-gray-900 mb-1 text-lg">
                            Horario de Atención
                        </h4>
                        <p class="text-gray-600 text-sm">
                            Lunes a Viernes<br />7:20 AM - 5:00 PM
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
