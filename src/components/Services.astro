---
---
<!-- ========== SECCIÓN SERVICIOS ========== -->
<section id="servicios" class="py-16 lg:py-24 bg-pattern relative">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center fade-in">
            <h2 class="text-4xl font-bold tracking-tight title-shadow mb-4">
                <span class="text-gradient">Servicios</span> Integrales
            </h2>
            <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-600 leading-relaxed">
                Ofrecemos un <strong class="text-[#0A2A4E]">abanico completo de servicios</strong> diseñados para cubrir las necesidades específicas de cada niño y familia.
            </p>
        </div>

        <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Servicio 1 -->
            <div class="service-card p-8 rounded-xl hover-lift scroll-animate">
                <div class="text-4xl mb-6 icon-bounce" style="color: #0D8F8F;">
                    <ion-icon name="clipboard-outline"></ion-icon>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gradient">Evaluación y diagnóstico</h3>
                <h4 class="text-sm font-semibold mb-3" style="color: #005960;">TEA, TDAH</h4>
                <p class="text-gray-600 leading-relaxed">Evaluación especializada para identificar y diagnosticar Trastorno del Espectro Autista y TDAH con precisión.</p>
            </div>

            <!-- Servicio 2 -->
            <div class="service-card p-8 rounded-xl hover-lift scroll-animate">
                <div class="text-4xl mb-6 icon-bounce" style="color: #0D8F8F;">
                    <ion-icon name="chatbubbles-outline"></ion-icon>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gradient">Terapia del lenguaje</h3>
                <h4 class="text-sm font-semibold mb-3" style="color: #005960;">Comunicación verbal y no verbal</h4>
                <p class="text-gray-600 leading-relaxed">Terapia especializada para mejorar las habilidades de comunicación verbal y no verbal.</p>
            </div>

            <!-- Servicio 3 -->
            <div class="service-card p-8 rounded-xl hover-lift scroll-animate">
                <div class="text-4xl mb-6 icon-bounce" style="color: #0D8F8F;">
                    <ion-icon name="body-outline"></ion-icon>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gradient">Terapia ocupacional</h3>
                <h4 class="text-sm font-semibold mb-3" style="color: #005960;">Integración sensorial</h4>
                <p class="text-gray-600 leading-relaxed">Intervenciones para mejorar la integración sensorial y las habilidades motoras finas y gruesas.</p>
            </div>

            <!-- Servicio 4 -->
            <div class="service-card p-8 rounded-xl hover-lift scroll-animate">
                <div class="text-4xl mb-6 icon-bounce" style="color: #0D8F8F;">
                    <ion-icon name="heart-outline"></ion-icon>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gradient">Psicología clínica</h3>
                <h4 class="text-sm font-semibold mb-3" style="color: #005960;">Apoyo emocional</h4>
                <p class="text-gray-600 leading-relaxed">Servicios profesionales de evaluación y apoyo psicológico especializado para niños y familias.</p>
            </div>

            <!-- Servicio 5 -->
            <div class="service-card p-8 rounded-xl hover-lift scroll-animate">
                <div class="text-4xl mb-6 icon-bounce" style="color: #0D8F8F;">
                    <ion-icon name="extension-puzzle-outline"></ion-icon>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gradient">Intervención conductual</h3>
                <h4 class="text-sm font-semibold mb-3" style="color: #005960;">ABA especializado</h4>
                <p class="text-gray-600 leading-relaxed">Estrategias especializadas basadas en ABA para mejorar conductas y habilidades adaptativas.</p>
            </div>

            <!-- Servicio 6 -->
            <div class="service-card p-8 rounded-xl hover-lift scroll-animate">
                <div class="text-4xl mb-6 icon-bounce" style="color: #0D8F8F;">
                    <ion-icon name="school-outline"></ion-icon>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gradient">Apoyo psicoeducativo</h3>
                <h4 class="text-sm font-semibold mb-3" style="color: #005960;">Inclusión escolar</h4>
                <p class="text-gray-600 leading-relaxed">Acompañamiento educativo especializado para optimizar el aprendizaje e inclusión escolar.</p>
            </div>

            <!-- Servicio 7 -->
            <div class="service-card p-8 rounded-xl hover-lift scroll-animate">
                <div class="text-4xl mb-6 icon-bounce" style="color: #0D8F8F;">
                    <ion-icon name="people-outline"></ion-icon>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gradient">Orientación familiar</h3>
                <h4 class="text-sm font-semibold mb-3" style="color: #005960;">Acompañamiento integral</h4>
                <p class="text-gray-600 leading-relaxed">Apoyo integral para familias, brindando herramientas y estrategias efectivas para el hogar.</p>
            </div>

            <!-- Servicio 8 -->
            <div class="service-card p-8 rounded-xl hover-lift scroll-animate">
                <div class="text-4xl mb-6 icon-bounce" style="color: #0D8F8F;">
                    <ion-icon name="happy-outline"></ion-icon>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gradient">Talleres grupales</h3>
                <h4 class="text-sm font-semibold mb-3" style="color: #005960;">Actividades inclusivas</h4>
                <p class="text-gray-600 leading-relaxed">Espacios de integración y desarrollo social a través de actividades grupales y talleres.</p>
            </div>
        </div>
    </div>
</section>
