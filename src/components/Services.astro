---
const services = [
  ["clipboard-outline", "Evaluación y diagnóstico", "Perfil del neurodesarrollo", "Valoraciones clínicas para identificar fortalezas, necesidades y definir una ruta de intervención clara."],
  ["chatbubbles-outline", "Terapia del lenguaje", "Comunicación y conexión", "Intervenciones para fortalecer expresión, comprensión y comunicación verbal o no verbal."],
  ["body-outline", "Terapia ocupacional", "Autonomía e integración sensorial", "Experiencias terapéuticas para trabajar motricidad, regulación sensorial y actividades cotidianas."],
  ["heart-outline", "Psicología clínica infantil", "Bienestar emocional", "Un espacio seguro para acompañar emociones, autoestima, adaptación y bienestar familiar."],
  ["extension-puzzle-outline", "Intervención conductual", "Habilidades para la vida", "Estrategias respetuosas para desarrollar habilidades adaptativas y reducir barreras de aprendizaje."],
  ["school-outline", "Apoyo psicoeducativo", "Aprendizaje e inclusión", "Acompañamiento escolar, técnicas de estudio y estrategias ajustadas a cada forma de aprender."],
  ["people-outline", "Orientación familiar", "Acompañamiento en casa", "Herramientas prácticas para que padres y cuidadores puedan sostener los avances cotidianos."],
  ["happy-outline", "Talleres grupales", "Habilidades sociales", "Espacios seguros para practicar interacción, amistad, turnos y participación con otros."],
  ["leaf-outline", "Masaje terapéutico", "Relajación y bienestar", "Técnicas profesionales para adultos orientadas a aliviar tensión, ansiedad y estrés diario."],
];
---

<section id="servicios" class="section-shell bg-[#f4faf8] bg-pattern">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <header class="max-w-4xl mx-auto text-center mb-12 lg:mb-16">
      <span class="section-kicker">Servicios integrales</span>
      <h2 class="section-title mt-5">Todo el apoyo que ofrecemos, en un mismo lugar.</h2>
      <p class="section-lead mt-6 max-w-3xl mx-auto">
        Cada servicio cumple una función importante dentro del proceso. Nuestro equipo los conecta de acuerdo con las necesidades de cada niño, adulto y familia.
      </p>
    </header>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {services.map(([icon, title, subtitle, text], index) => (
        <article class="group relative min-h-[20rem] sm:min-h-[22rem] p-7 sm:p-9 bg-white/82 border border-white rounded-[1.75rem] flex flex-col shadow-[0_16px_45px_rgba(8,64,73,.09)] transition-[transform,background-color,box-shadow] duration-300 hover:-translate-y-1.5 hover:bg-[#063b45] hover:shadow-[0_24px_55px_rgba(6,59,69,.2)]">
          <div class="flex items-start justify-between gap-4">
            <div class="w-12 h-12 rounded-2xl bg-[#dff8f1] text-[#0b8f88] flex items-center justify-center transition-colors duration-300 group-hover:bg-white/12 group-hover:text-[#bdeee8]">
              <ion-icon name={icon} class="text-2xl" aria-hidden="true"></ion-icon>
            </div>
            <span class="font-display text-2xl font-bold text-[#0b8f88]/30 transition-colors duration-300 group-hover:text-white/25">{String(index + 1).padStart(2, '0')}</span>
          </div>

          <div class="mt-auto pt-10">
            <p class="text-sm font-extrabold text-[#0b8f88] mb-3 transition-colors duration-300 group-hover:text-[#bdeee8]">{subtitle}</p>
            <h3 class="text-2xl font-extrabold text-[#063b45] leading-tight transition-colors duration-300 group-hover:text-white">{title}</h3>
            <p class="mt-4 text-slate-600 leading-relaxed transition-colors duration-300 group-hover:text-white/70">{text}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 text-center">
      <p class="text-slate-600">¿No sabes cuál servicio necesita tu familia?</p>
      <a href="#evaluacion" class="btn-modern btn-filled">Solicitar una evaluación</a>
    </div>
  </div>
</section>
