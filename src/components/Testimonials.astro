---
const testimonials = [
  ["MR", "Daniela Rodríguez", "Madre de paciente", "Yo nunca imaginé que encontraría un lugar donde mi hijo se sintiera comprendido y apoyado. Gracias al equipo de CIATEJ, hemos visto avances significativos."],
  ["CL", "Carlos López", "Padre de paciente", "Yo matricule a mi hijo en CIATEJ,desde el momento uno mi hijo a tenido grandes cambios, los recomiento 100%."],
  ["AG", "Guadalupe García", "Madre de paciente", "La atención personalizada y el seguimiento continuo marcaron una diferencia en el desarrollo de nuestra hija."],
];
---

<section class="section-shell bg-[#f3fbf8]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <span class="section-kicker">Historias que inspiran</span>
      <h2 class="section-title mt-5">Familias que avanzan acompañadas.</h2>
      <p class="section-lead mt-6">Testimonios de confianza, progreso y cercanía terapéutica.</p>
    </div>

    <div class="mt-14 grid md:grid-cols-3 gap-5">
      {testimonials.map(([initials, name, role, quote]) => (
        <article class="testimonial-card p-7 hover-lift scroll-animate">
          <div class="flex text-[#f1b84b] mb-5" aria-label="Calificación de 5 estrellas">
            <ion-icon name="star"></ion-icon><ion-icon name="star"></ion-icon><ion-icon name="star"></ion-icon><ion-icon name="star"></ion-icon><ion-icon name="star"></ion-icon>
          </div>
          <p class="text-slate-700 leading-relaxed mb-7">“{quote}”</p>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#063b45] to-[#0b8f88] text-white font-extrabold flex items-center justify-center">{initials}</div>
            <div>
              <h3 class="font-extrabold text-[#063b45]">{name}</h3>
              <p class="text-sm text-slate-500">{role}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12 fade-in">
      <div class="liquid-card max-w-2xl mx-auto p-8">
        <h3 class="text-2xl font-extrabold text-[#063b45] mb-3">¿Quieres dar el primer paso?</h3>
        <p class="text-slate-600 mb-6">Cuéntanos tu caso y nuestro equipo te orientará con claridad.</p>
        <a href="#evaluacion" class="btn-modern btn-filled">Comenzar evaluación</a>
      </div>
    </div>
  </div>
</section>
